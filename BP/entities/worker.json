{
  "format_version": "1.20.50",
  "minecraft:entity": {
    "description": {
      "identifier": "searmr:worker",
      "is_summonable": true,
      "is_spawnable": false
    },
    "component_groups": {
      "searmr:despawn": {
        "minecraft:instant_despawn": {}
      }
    },
    "components": {
      "minecraft:persistent": {},
      "minecraft:environment_sensor": {
        "triggers": {
          "filters": {
            "test": "has_tag",
            "value": "done"
          },
          "event": "despawn"
        }
      },

      "minecraft:pushable": {
        "is_pushable": false
      },
      "minecraft:physics": {
        "has_collision": false,
        "has_gravity": false
      },
      "minecraft:collision_box": {
        "height": 0,
        "width": 0
      },
      "minecraft:tick_world": {
        "never_despawn": true,
        "radius": 2
      },
      "minecraft:damage_sensor": {
        "triggers": {
          "cause": "all",
          "deals_damage": false
        }
      }
    },
    "events": {
      "despawn": {
        "add": {
          "component_groups": ["searmr:despawn"]
        }
      }
    }
  }
}
